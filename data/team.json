{
  "leadership": [
    { "name": "Prof. Kamakoti Veezhinathan", "role": "Director, IIT Madras", "photo": "", "linkedin": "https://www.linkedin.com/in/kamakoti-veezhinathan-9a8528b/", "message": "The School of Innovation & Entrepreneurship provides the academic foundation to IITM's 'I&E Stack' and will train the coming generation of startup founders who will produce distinctive solutions addressing some of the most pressing industrial and societal challenges. SIE at IIT Madras is one of our key initiatives towards the vision of Viksit Bharat 2047 and is aligned with visionary programmes such as Make in India, Swachh Bharat and NEP." },
    { "name": "Prof. Satyanarayanan Seshadri", "role": "Head, School of Innovation and Entrepreneurship", "photo": "/images/people/satyanarayanan-seshadri.jpg", "linkedin": "https://www.linkedin.com/in/satyaseshadri/", "message": "SIE at IIT Madras is leading its transformation into India's foremost entrepreneurial university. Our vision is to be among the top 5 global entrepreneurial universities and to propel India as a top-3 deep-tech, science-based startup nation. SIE pioneers an active venture-creation model, where research to revenue is supported at every step through our innovation stack — tinkering labs, deep-tech centres of excellence, pre-incubation, lab-to-market education and venture studios." },
    { "name": "Prof. Murugaiyan Amirthalingam", "role": "Advisor, Nirmaan", "photo": "/images/people/murugaiyan-amirthalingam.jpg", "linkedin": "", "message": "Nirmaan, the pre-incubator at IIT Madras, supports students, researchers and alumni taking their first steps into entrepreneurship. It turns early ideas and prototypes into real startup opportunities through mentorship, seed funding, prototyping support and access to the wider IIT Madras startup ecosystem — working closely with aspiring founders from concept to a strong, scalable venture." },
    { "name": "Prof. Manish Anand", "role": "Advisor, CFI", "photo": "/images/people/manish-anand.jpg", "linkedin": "https://www.linkedin.com/in/manish-anand-80985a170/", "message": "The Centre for Innovation is where IIT Madras students learn by doing — a 24/7 student-run lab where ideas are built, broken and rebuilt until they work. CFI is the first step of the founder pipeline at IIT Madras." }
  ],
